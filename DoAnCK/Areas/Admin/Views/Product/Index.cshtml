<!-- ===================== PRICE MANAGEMENT SCRIPT ===================== -->

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const productSelect = document.getElementById("priceProductSelect");
        const priceProductSearch = document.getElementById("priceProductSearch");
        const updateType = document.getElementById("priceUpdateType");
        const percentInput = document.getElementById("percentInput");
        const giaMoiInput = document.getElementById("giaMoiInput");
        const currentPriceText = document.getElementById("currentPriceText");
        const currentProductText = document.getElementById("currentProductText");
        const newPricePreview = document.getElementById("newPricePreview");

        const btnMinus = document.getElementById("btnMinusPercent");
        const btnPlus = document.getElementById("btnPlusPercent");

        let originalOptions = [];

        if (productSelect) {
            originalOptions = Array.from(productSelect.options).map(function (option) {
                return {
                    value: option.value,
                    text: option.text,
                    price: option.getAttribute("data-price"),
                    name: option.getAttribute("data-name")
                };
            });
        }

        function formatMoney(value) {
            return Number(value).toLocaleString("vi-VN") + "đ";
        }

        function getCurrentOption() {
            if (!productSelect || productSelect.selectedIndex < 0) {
                return null;
            }

            return productSelect.options[productSelect.selectedIndex];
        }

        function getCurrentPrice() {
            const selected = getCurrentOption();

            if (!selected) {
                return 0;
            }

            return Number(selected.getAttribute("data-price")) || 0;
        }

        function getCurrentName() {
            const selected = getCurrentOption();

            if (!selected) {
                return "Chưa có sản phẩm";
            }

            return selected.getAttribute("data-name") || selected.text;
        }

        function calculateNewPrice() {
            const currentPrice = getCurrentPrice();
            const percent = Number(percentInput.value) || 0;
            const type = updateType ? updateType.value : "increase";

            let newPrice = currentPrice;

            if (type === "increase") {
                newPrice = currentPrice + (currentPrice * percent / 100);
            }
            else if (type === "decrease" || type === "discount") {
                newPrice = currentPrice - (currentPrice * percent / 100);
            }
            else if (type === "restore") {
                newPrice = currentPrice;
            }

            if (newPrice < 0) {
                newPrice = 0;
            }

            return Math.round(newPrice);
        }

        function updatePreview() {
            const currentPrice = getCurrentPrice();
            const newPrice = calculateNewPrice();

            if (currentPriceText) {
                currentPriceText.innerText = formatMoney(currentPrice);
            }

            if (currentProductText) {
                currentProductText.innerText = getCurrentName();
            }

            if (newPricePreview) {
                newPricePreview.innerText = formatMoney(newPrice);
            }

            if (giaMoiInput) {
                giaMoiInput.value = newPrice;
            }
        }

        function rebuildOptions(keyword) {
            if (!productSelect) {
                return;
            }

            const searchText = keyword.toLowerCase().trim();

            productSelect.innerHTML = "";

            const filteredOptions = originalOptions.filter(function (item) {
                return item.text.toLowerCase().includes(searchText);
            });

            filteredOptions.forEach(function (item) {
                const option = document.createElement("option");

                option.value = item.value;
                option.text = item.text;

                option.setAttribute("data-price", item.price);
                option.setAttribute("data-name", item.name);

                productSelect.appendChild(option);
            });

            if (filteredOptions.length > 0) {
                productSelect.selectedIndex = 0;
                updatePreview();
            }
            else {
                if (currentPriceText) {
                    currentPriceText.innerText = "0đ";
                }

                if (currentProductText) {
                    currentProductText.innerText = "Không tìm thấy sản phẩm";
                }

                if (newPricePreview) {
                    newPricePreview.innerText = "0đ";
                }

                if (giaMoiInput) {
                    giaMoiInput.value = "";
                }
            }
        }

        if (productSelect) {
            productSelect.addEventListener("change", updatePreview);
        }

        if (priceProductSearch) {
            priceProductSearch.addEventListener("input", function () {
                rebuildOptions(priceProductSearch.value);
            });
        }

        if (updateType) {
            updateType.addEventListener("change", updatePreview);
        }

        if (percentInput) {
            percentInput.addEventListener("input", updatePreview);
        }

        if (giaMoiInput) {
            giaMoiInput.addEventListener("input", function () {
                const value = Number(giaMoiInput.value) || 0;

                if (newPricePreview) {
                    newPricePreview.innerText = formatMoney(value);
                }
            });
        }

        if (btnMinus) {
            btnMinus.addEventListener("click", function () {
                let value = Number(percentInput.value) || 0;

                if (value > 0) {
                    value = value - 1;
                }

                percentInput.value = value;

                updatePreview();
            });
        }

        if (btnPlus) {
            btnPlus.addEventListener("click", function () {
                let value = Number(percentInput.value) || 0;

                value = value + 1;

                percentInput.value = value;

                updatePreview();
            });
        }

        updatePreview();
    });
</script>
