</div>


<!-- ===================== CHART SCRIPT ===================== -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    const ctx = document.getElementById('revenueChart');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'],
            datasets: [{
                label: 'Doanh thu',
                data: [120, 190, 160, 250, 220, 310, 380],
                borderColor: '#b08a63',
                backgroundColor: 'rgba(176, 138, 99, 0.18)',
                pointBackgroundColor: '#7b5738',
                pointBorderColor: '#7b5738',
                pointRadius: 4,
                pointHoverRadius: 6,
                borderWidth: 3,
                tension: 0.4,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,

            plugins: {
                legend: {
                    display: false
                }
            },

            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: '#efe5da'
                    },
                    ticks: {
                        color: '#7f7368'
                    }
                },
                x: {
                    grid: {
                        display: false
                    },
                    ticks: {
                        color: '#7f7368'
                    }
                }
            }
        }
    });

</script>