@{
    ViewBag.Title = "Dashboard";
}

<!-- ===================== PAGE TITLE ===================== -->

<div class="page-title fade-up">

    <div>
        <h2>Dashboard</h2>
        <p>Chào mừng quay lại, Admin. Đây là tổng quan hoạt động cửa hàng nội thất hôm nay.</p>
    </div>

    <div>
        <a href="/Admin/Product/Create" class="btn-admin">
            <i class="fa-solid fa-plus"></i>
            Thêm sản phẩm
        </a>
    </div>

</div>


<!-- ===================== STATISTICS ===================== -->

<div class="dashboard fade-up">

    @Html.Action("_TotalRevenue", "Dashboard")


    @Html.Action("_TotalOrders", "Dashboard")


    <div class="stat-card">

        <div class="stat-top">

            <div>
                <div class="stat-title">Khách hàng</div>
                <div class="stat-value">1.258</div>
                <div class="stat-footer">
                    <i class="fa-solid fa-arrow-trend-up"></i>
                    +5.4% so với tháng trước
                </div>
            </div>

            <div class="stat-icon bg-orange">
                <i class="fa-solid fa-users"></i>
            </div>

        </div>

    </div>


    @Html.Action("_TotalProductSales", "Dashboard")

</div>


<!-- ===================== MAIN CONTENT ===================== -->

<div class="content-grid fade-up">

    <!-- Revenue Chart -->

    <div class="card-box">

        <div class="card-header">

            <div>
                <div class="card-title">Tổng quan doanh thu</div>
                <small class="text-muted">Hiệu suất doanh thu theo tháng</small>
            </div>

            <a href="#" class="card-link">
                Xem báo cáo
            </a>

        </div>

        <div class="chart-box">
            <canvas id="revenueChart"></canvas>
        </div>

    </div>


    <!-- Top Categories -->

    @Html.Action("_TopCategories", "Dashboard")

</div>


