@model IEnumerable<DoAnCK.Areas.Admin.Models.BestSellerViewModel>

<div class="card-box" style="width: 100%; min-height: 100%;">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
        <div>
            <div class="card-title">Sản phẩm bán chạy</div>
            <small class="text-muted">Các sản phẩm nội thất được mua nhiều nhất</small>
        </div>
        <a href="/Admin/Product" class="card-link" style="white-space: nowrap; margin-left: 15px;">Xem tất cả</a>
    </div>

    <div class="table-responsive" style="width: 100%; margin-top: 15px;">
        <table class="table" style="width: 100%; table-layout: fixed; margin-bottom: 0;">
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <!-- Cột thông tin sản phẩm: Chiếm 60% chiều ngang -->
                            <td style="width: 60%; vertical-align: middle; border-bottom: 1px solid #f0f0f0; padding: 12px 8px;">
                                <div class="product-info" style="display: flex; align-items: center; gap: 15px;">
                                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                                    {
                                        <img src="@Url.Content(item.HinhAnh)" alt="@item.TenSP" style="width: 64px; height: 64px; object-fit: cover; border-radius: 12px; flex-shrink: 0;" />
                                    }
                                    else
                                    {
                                        <img src="@Url.Content("~/Content/images/default-thumbnail.jpg")" alt="No Image" style="width: 64px; height: 64px; object-fit: cover; border-radius: 12px; flex-shrink: 0;" />
                                    }
                                    <div style="overflow: hidden;">
                                        <h6 style="margin: 0 0 4px 0; font-size: 15px; font-weight: 600; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@item.TenSP</h6>
                                        <span style="font-size: 13px; color: #888;">@item.TenDanhMuc</span>
                                    </div>
                                </div>
                            </td>

                            <!-- Cột số lượng bán: Chiếm 20% chiều ngang -->
                            <td style="width: 20%; vertical-align: middle; text-align: center; border-bottom: 1px solid #f0f0f0; padding: 12px 8px; font-size: 14px; color: #555; white-space: nowrap;">
                                <strong style="color: #2c3e50; font-size: 16px;">@item.TongDaBan</strong> đã bán
                            </td>

                            <!-- Cột giá bán: Chiếm 20% chiều ngang -->
                            <td class="text-end" style="width: 20%; vertical-align: middle; text-align: right; border-bottom: 1px solid #f0f0f0; padding: 12px 8px; font-weight: bold; font-size: 15px; color: #2c3e50; white-space: nowrap;">
                                @string.Format("{0:N0}đ", item.GiaBan)
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center py-4 text-muted">
                            Chưa có dữ liệu bán hàng.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>