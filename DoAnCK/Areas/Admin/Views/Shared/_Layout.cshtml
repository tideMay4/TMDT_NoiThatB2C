@{
    Layout = null;

    var currentController = ViewContext.RouteData.Values["controller"].ToString();
}

<!DOCTYPE html>

<html lang="vi">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewBag.Title - MODERNO Admin</title>

    <!-- Bootstrap -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- Font Awesome -->

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          rel="stylesheet" />

    <!-- Google Font -->

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">

    <!-- CSS -->

    <link href="~/Areas/Admin/Content/admin.css"
          rel="stylesheet" />

</head>

<body>

    <div class="wrapper">

        <!--=========================
                SIDEBAR
        ==========================-->

        <aside class="sidebar">

            <div class="logo">

                <div class="logo-icon">

                    <i class="fa-solid fa-couch"></i>

                </div>

                <div class="logo-text">

                    <h4>MODERNO</h4>

                    <span>Admin Panel</span>

                </div>

            </div>

            <ul class="menu">

                <li class="@(currentController == "Dashboard" ? "active" : "")">

                    <a href="/Admin/Dashboard">

                        <i class="fa-solid fa-table-columns"></i>

                        <span>Dashboard</span>

                    </a>

                </li>

                <li class="@(currentController == "Product" ? "active" : "")">

                    <a href="/Admin/Product">

                        <i class="fa-solid fa-couch"></i>

                        <span>Products</span>

                    </a>

                </li>

                <li class="@(currentController == "Category" ? "active" : "")">

                    <a href="/Admin/Category">

                        <i class="fa-solid fa-layer-group"></i>

                        <span>Categories</span>

                    </a>

                </li>

                <li class="@(currentController == "Order" ? "active" : "")">

                    <a href="/Admin/Order">

                        <i class="fa-solid fa-cart-shopping"></i>

                        <span>Orders</span>

                    </a>

                </li>

                <li class="@(currentController == "Customer" ? "active" : "")">

                    <a href="/Admin/Customer">

                        <i class="fa-solid fa-users"></i>

                        <span>Customers</span>

                    </a>

                </li>

                <li class="@(currentController == "Banner" ? "active" : "")">

                    <a href="/Admin/Banner">

                        <i class="fa-solid fa-image"></i>

                        <span>Banner</span>

                    </a>

                </li>

                <li class="@(currentController == "Seo" ? "active" : "")">

                    <a href="/Admin/Seo">

                        <i class="fa-solid fa-magnifying-glass"></i>

                        <span>SEO</span>

                    </a>

                </li>

                <li class="@(currentController == "Statistic" ? "active" : "")">

                    <a href="/Admin/Statistic">

                        <i class="fa-solid fa-chart-line"></i>

                        <span>Statistics</span>

                    </a>

                </li>

                <li class="@(currentController == "Setting" ? "active" : "")">

                    <a href="/Admin/Setting">

                        <i class="fa-solid fa-gear"></i>

                        <span>Settings</span>

                    </a>

                </li>

            </ul>

            <div class="sidebar-bottom">

                <a href="/">

                    <i class="fa-solid fa-arrow-left"></i>

                    Back to Website

                </a>

            </div>

        </aside>

        <!--=========================
                CONTENT
        ==========================-->

        <main class="main-content">

            <!--=====================
                  HEADER
            ======================-->

            <header class="topbar">

                <div class="top-left">

                    <button class="menu-btn">

                        <i class="fa-solid fa-bars"></i>

                    </button>

                    <div class="search-box">

                        <i class="fa fa-search"></i>

                        <input type="text"
                               placeholder="Search..." />

                    </div>

                </div>

                <div class="top-right">

                    <button class="icon-btn">

                        <i class="fa-regular fa-bell"></i>

                        <span class="badge-dot"></span>

                    </button>

                    <button class="icon-btn">

                        <i class="fa-regular fa-envelope"></i>

                    </button>

                    <div class="user-box">

                        <img src="https://i.pravatar.cc/45?img=15"
                             alt="admin" />

                        <div>

                            <h6>Administrator</h6>

                            <span>Online</span>

                        </div>

                    </div>

                </div>

            </header>

            <!--=====================
                  PAGE
            ======================-->

            <section class="page-content">

                @RenderBody()

            </section>

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>