@model IEnumerable<DoAnCK.Areas.Admin.Models.CategoryViewModel>

@{
    ViewBag.Title = "Quản lý danh mục";
}

<div class="page-title fade-up">

    <div>
        <h2>Quản lý danh mục</h2>
        <p>Quản lý các danh mục sản phẩm nội thất trên website.</p>
    </div>

    <div>
        <button class="btn-admin" data-bs-toggle="modal" data-bs-target="#createCategoryModal">
            <i class="fa-solid fa-plus"></i>
            Thêm danh mục
        </button>
    </div>

</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}


<div class="table-box fade-up">

    <div class="card-header">

        <div>
            <div class="card-title">Danh sách danh mục</div>
            <small class="text-muted">Tất cả danh mục đang có trong hệ thống</small>
        </div>

        <div class="d-flex gap-2">

            <button class="btn-outline-admin">
                <i class="fa-solid fa-download"></i>
                Xuất Excel
            </button>

            <button class="btn-outline-admin">
                <i class="fa-solid fa-filter"></i>
                Bộ lọc
            </button>

        </div>

    </div>


    <div class="filter-bar">

        <div class="filter-left">

            <input type="text"
                   class="form-control"
                   placeholder="Tìm kiếm danh mục..."
                   style="width:300px;" />

            <select class="form-select" style="width:180px;">
                <option>Tất cả trạng thái</option>
                <option>Đang hiển thị</option>
                <option>Đang ẩn</option>
            </select>

        </div>

        <div class="filter-right">

            <select class="form-select" style="width:160px;">
                <option>Mới nhất</option>
                <option>Cũ nhất</option>
                <option>Nhiều sản phẩm</option>
            </select>

        </div>

    </div>


    <div class="table-responsive">

        <table class="table category-table">

            <thead>

                <tr>
                    <th style="width:70px;">Mã</th>
                    <th>Danh mục</th>
                    <th>Slug SEO</th>
                    <th>Mô tả</th>
                    <th>Sản phẩm</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Thao tác</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            #@item.MaDM
                        </td>

                        <td>
                            <div class="category-info">

                                <img src="@Url.Content(item.HinhAnh)" />

                                <div>
                                    <h6>@item.TenDM</h6>
                                    <span>Danh mục nội thất</span>
                                </div>

                            </div>
                        </td>

                        <td>
                            <span class="slug-text">
                                /@item.Slug
                            </span>
                        </td>

                        <td class="category-desc">
                            @item.MoTa
                        </td>

                        <td>
                            <strong>@item.SoSanPham</strong>
                        </td>

                        <td>
                            @if (item.TrangThai)
                            {
                                <span class="badge-success">
                                    Đang hiển thị
                                </span>
                            }
                            else
                            {
                                <span class="badge-danger">
                                    Đang ẩn
                                </span>
                            }
                        </td>

                        <td>
                            @item.NgayTao.ToString("dd/MM/yyyy")
                        </td>

                        <td class="text-end">

                            <button class="btn btn-light btn-sm action-btn"
                                    title="Xem chi tiết">

                                <i class="fa-solid fa-eye"></i>

                            </button>

                            <button class="btn btn-light btn-sm action-btn"
                                    title="Sửa danh mục"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editCategoryModal_@item.MaDM">

                                <i class="fa-solid fa-pen"></i>

                            </button>

                            <button class="btn btn-light btn-sm action-btn text-danger"
                                    title="Xóa danh mục"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteCategoryModal_@item.MaDM">

                                <i class="fa-solid fa-trash"></i>

                            </button>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>


    <nav>

        <ul class="pagination">

            <li class="page-item active">
                <a class="page-link" href="#">1</a>
            </li>

            <li class="page-item">
                <a class="page-link" href="#">2</a>
            </li>

            <li class="page-item">
                <a class="page-link" href="#">3</a>
            </li>

            <li class="page-item">
                <a class="page-link" href="#">
                    <i class="fa-solid fa-angle-right"></i>
                </a>
            </li>

        </ul>

    </nav>

</div>


@foreach (var item in Model)
{
    <!-- MODAL SỬA DANH MỤC -->

    <div class="modal fade" id="editCategoryModal_@item.MaDM" tabindex="-1">

        <div class="modal-dialog modal-lg modal-dialog-centered">

            <div class="modal-content admin-modal">

                @using (Html.BeginForm("Edit", "Category", FormMethod.Post, new { area = "Admin", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="MaDM" value="@item.MaDM" />

                    <div class="modal-header">

                        <div>
                            <h5 class="modal-title">Sửa danh mục</h5>
                            <small class="text-muted">Cập nhật thông tin danh mục sản phẩm</small>
                        </div>

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"></button>

                    </div>

                    <div class="modal-body">

                        <div class="row g-4">

                            <div class="col-md-6">

                                <label class="form-label">Tên danh mục</label>

                                <input type="text"
                                       name="TenDM"
                                       class="form-control"
                                       value="@item.TenDM"
                                       required />

                            </div>

                            <div class="col-md-6">

                                <label class="form-label">Slug SEO</label>

                                <input type="text"
                                       name="Slug"
                                       class="form-control"
                                       value="@item.Slug" />

                            </div>

                            <div class="col-md-12">

                                <label class="form-label">Mô tả</label>

                                <textarea name="MoTa"
                                          class="form-control"
                                          rows="4">@item.MoTa</textarea>

                            </div>

                            <div class="col-md-6">

                                <label class="form-label">Đổi hình ảnh</label>

                                <input type="file"
                                       name="HinhAnhFile"
                                       class="form-control"
                                       accept="image/*" />

                            </div>

                            <div class="col-md-6">

                                <label class="form-label">Trạng thái</label>

                                <select name="TrangThai" class="form-select">

                                    @if (item.TrangThai)
                                    {
                                        <option value="true" selected="selected">Đang hiển thị</option>
                                        <option value="false">Đang ẩn</option>
                                    }
                                    else
                                    {
                                        <option value="true">Đang hiển thị</option>
                                        <option value="false" selected="selected">Đang ẩn</option>
                                    }

                                </select>

                            </div>

                        </div>

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="btn-outline-admin"
                                data-bs-dismiss="modal">

                            Hủy

                        </button>

                        <button type="submit"
                                class="btn-admin">

                            <i class="fa-solid fa-floppy-disk"></i>
                            Lưu thay đổi

                        </button>

                    </div>
                }

            </div>

        </div>

    </div>


    <!-- MODAL XÓA DANH MỤC -->

    <div class="modal fade" id="deleteCategoryModal_@item.MaDM" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content admin-modal">

                @using (Html.BeginForm("Delete", "Category", FormMethod.Post, new { area = "Admin" }))
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="MaDM" value="@item.MaDM" />

                    <div class="modal-header">

                        <div>
                            <h5 class="modal-title">Xóa danh mục</h5>
                            <small class="text-muted">Xác nhận xóa danh mục khỏi hệ thống</small>
                        </div>

                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"></button>

                    </div>

                    <div class="modal-body">

                        <p>
                            Bạn có chắc chắn muốn xóa danh mục
                            <strong>@item.TenDM</strong>
                            không?
                        </p>

                        <p class="text-muted mb-0">
                            Nếu danh mục đang có sản phẩm, hệ thống sẽ không cho xóa để tránh lỗi dữ liệu.
                        </p>

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="btn-outline-admin"
                                data-bs-dismiss="modal">

                            Hủy

                        </button>

                        <button type="submit"
                                class="btn-admin">

                            <i class="fa-solid fa-trash"></i>
                            Xác nhận xóa

                        </button>

                    </div>
                }

            </div>

        </div>

    </div>
}

<!-- ===================== MODAL THÊM DANH MỤC ===================== -->

<div class="modal fade" id="createCategoryModal" tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content admin-modal">

            @using (Html.BeginForm("Create", "Category", FormMethod.Post, new { area = "Admin", enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                <div class="modal-header">

                    <div>
                        <h5 class="modal-title">Thêm danh mục mới</h5>
                        <small class="text-muted">Tạo danh mục sản phẩm nội thất</small>
                    </div>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">

                    <div class="row g-4">

                        <div class="col-md-6">

                            <label class="form-label">Tên danh mục</label>

                            <input type="text"
                                   name="TenDM"
                                   class="form-control"
                                   placeholder="Ví dụ: Sofa, Bàn, Giường ngủ..."
                                   required />

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">Slug SEO</label>

                            <input type="text"
                                   name="Slug"
                                   class="form-control"
                                   placeholder="vi-du: sofa-phong-khach" />

                        </div>

                        <div class="col-md-12">

                            <label class="form-label">Mô tả</label>

                            <textarea name="MoTa"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Nhập mô tả ngắn cho danh mục..."></textarea>

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">Hình ảnh</label>

                            <input type="file"
                                   name="HinhAnhFile"
                                   class="form-control"
                                   accept="image/*" />

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">Trạng thái</label>

                            <select name="TrangThai" class="form-select">

                                <option value="true">Đang hiển thị</option>

                                <option value="false">Đang ẩn</option>

                            </select>

                        </div>

                    </div>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn-outline-admin"
                            data-bs-dismiss="modal">

                        Hủy

                    </button>

                    <button type="submit"
                            class="btn-admin">

                        <i class="fa-solid fa-floppy-disk"></i>
                        Lưu danh mục

                    </button>

                </div>
            }

        </div>

    </div>

</div>