<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
        $(document).ready(function () {
            // Phần 1: Tính toán tổng tiền
            const SHIPPING_FEE = @(Model != null ? Model.ShippingFee : 0);
            const BULKY_ITEM_FEE = @(Model != null ? Model.BulkyFeePerItem : 0);

            function calculateTotal() {
                let subTotal = 0;
                let hasBulkyItem = false;

                $('.cart-item').each(function () {
                    let price = parseFloat($(this).find('.item-price').attr('data-price')) || 0;
                    subTotal += price;

                    if ($(this).attr('data-is-bulky') === "true") {
                        hasBulkyItem = true;
                    }
                });

                let currentBulkyFee = hasBulkyItem ? BULKY_ITEM_FEE : 0;
                let total = subTotal + SHIPPING_FEE + currentBulkyFee;

                $('#subTotal').text(subTotal.toLocaleString('vi-VN') + ' ₫');
                $('#shippingFee').text(SHIPPING_FEE.toLocaleString('vi-VN') + ' ₫');
                $('#bulkyFee').text(currentBulkyFee.toLocaleString('vi-VN') + ' ₫');
                $('#totalPrice').text(total.toLocaleString('vi-VN') + ' ₫');
            }

            calculateTotal();

            // Phần 2: Hiển thị/Ẩn QR Code
            $('input[name="PaymentType"]').change(function () {
                if ($(this).val() === 'QR_BANK') { // Mình sửa lại 'QR' thành 'QR_BANK' cho khớp C# của bạn nhé
                    $('#qrCodeSection').slideDown();
                } else {
                    $('#qrCodeSection').slideUp();
                }
            });

            // Phần 3: Xử lý nút Đặt hàng
            $('#btnPlaceOrder').click(function () {
                let rawTotal = $('#totalPrice').text().replace(/\./g, '').replace(' ₫', '').trim();

                let formData = {
                    FullName: $('input[name="FullName"]').val(),
                    PhoneNumber: $('input[name="PhoneNumber"]').val(),
                    Address: $('#street').val() ? ($('#street').val() + ', ' + $('#ward option:selected').text() + ', ' + $('#district option:selected').text() + ', ' + $('#city option:selected').text()) : $('input[name="Address"]').val(),
                    PaymentMethod: $('input[name="PaymentType"]:checked').val(),
                    TotalPrice: parseInt(rawTotal)
                };

                if (!formData.FullName || !formData.PhoneNumber) {
                    alert("Vui lòng nhập đầy đủ Họ tên và Số điện thoại giao hàng!");
                    return;
                }

                $(this).text('Đang xử lý đơn hàng...').prop('disabled', true);

                if (formData.PaymentMethod === 'QR_MOMO') {
                    $.ajax({
                        url: '/Checkout/PaymentWithMoMo',
                        type: 'POST',
                        data: formData,
                        success: function (res) {
                            if (res.success && res.url) {
                                window.location.href = res.url;
                            } else {
                                alert("Không thể khởi tạo thanh toán MoMo: " + (res.message || "Lỗi hệ thống"));
                                $('#btnPlaceOrder').text('ĐẶT HÀNG').prop('disabled', false);
                            }
                        },
                        error: function () {
                            alert("Lỗi kết nối đến server MoMo.");
                            $('#btnPlaceOrder').text('ĐẶT HÀNG').prop('disabled', false);
                        }
                    });

                } else if (formData.PaymentMethod === 'QR_BANK') {
                    // Bạn đang làm tích hợp PayOS ở bước trước, nên đổi '/Checkout/CreateVietQR' thành '/Checkout/PaymentWithPayOS'
                    $.ajax({
                        url: '/Checkout/PaymentWithPayOS',
                        type: 'POST',
                        data: formData,
                        success: function (res) {
                            if (res.success && res.url) {
                                // Nếu dùng PayOS, nhảy sang trang PayOS quét mã
                                window.location.href = res.url;
                            } else {
                                alert("Không thể tạo mã VietQR lúc này: " + res.message);
                                $('#btnPlaceOrder').text('ĐẶT HÀNG').prop('disabled', false);
                            }
                        },
                        error: function() {
                            alert("Lỗi kết nối PayOS.");
                            $('#btnPlaceOrder').text('ĐẶT HÀNG').prop('disabled', false);
                        }
                    });

                } else {
                    $.ajax({
                        url: '/Checkout/ProcessCOD',
                        type: 'POST',
                        data: formData,
                        success: function (res) {
                            if (res.success) {
                                window.location.href = '/Checkout/OrderSuccess?orderCode=' + res.orderCode;
                            } else {
                                alert("Đã xảy ra lỗi khi lưu đơn hàng.");
                                $('#btnPlaceOrder').text('ĐẶT HÀNG').prop('disabled', false);
                            }
                        }
                    });
                }
            });
        });

        // Phần 4: Gọi API Tỉnh/Thành phố
        $(document).ready(function () {
            $.ajax({
                url: "https://provinces.open-api.vn/api/?depth=3",
                method: "GET",
                success: function (data) {
                    let cityHtml = '<option value="" selected disabled>Chọn Tỉnh / Thành phố</option>';
                    $.each(data, function (index, city) {
                        cityHtml += `<option value="${city.code}" data-name="${city.name}">${city.name}</option>`;
                    });
                    $("#city").html(cityHtml);

                    $("#city").change(function () {
                        let cityCode = $(this).val();
                        let cityName = $(this).find(':selected').data('name');

                        $("#txtCityName").val(cityName);
                        updateShippingFee(cityName);

                        let selectedCity = data.find(c => c.code == cityCode);
                        let districtHtml = '<option value="" selected disabled>Chọn Quận / Huyện</option>';

                        if (selectedCity && selectedCity.districts) {
                            $.each(selectedCity.districts, function (index, district) {
                                districtHtml += `<option value="${district.code}">${district.name}</option>`;
                            });
                        }
                        $("#district").html(districtHtml);
                        $("#ward").html('<option value="" selected disabled>Chọn Phường / Xã</option>');
                    });

                    $("#district").change(function () {
                        let cityCode = $("#city").val();
                        let districtCode = $(this).val();
                        let selectedCity = data.find(c => c.code == cityCode);
                        let selectedDistrict = selectedCity.districts.find(d => d.code == districtCode);

                        let wardHtml = '<option value="" selected disabled>Chọn Phường / Xã</option>';
                        if (selectedDistrict && selectedDistrict.wards) {
                            $.each(selectedDistrict.wards, function (index, ward) {
                                wardHtml += `<option value="${ward.code}">${ward.name}</option>`;
                            });
                        }
                        $("#ward").html(wardHtml);
                    });
                }
            });

            function updateShippingFee(cityName) {
                $.post('/Checkout/CalculatePriceByLocation', { cityName: cityName }, function (res) {
                    if (res.success) {
                        $('#shippingFee').text(res.shippingFee.toLocaleString('vi-VN') + ' ₫');
                        $('#totalPrice').text(res.totalPrice.toLocaleString('vi-VN') + ' ₫');
                    }
                });
            }
        });
</script>