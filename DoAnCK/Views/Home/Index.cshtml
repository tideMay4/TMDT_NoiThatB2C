<section class="home-arrivals">
    <h3 class="section-title">NEW ARRIVALS</h3>

    <div class="home-arrival-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model.Take(6))
            {
                var hinhAnh = string.IsNullOrEmpty(item.HinhAnh) ? "~/Content/images/no-image.jpg" : item.HinhAnh;

                <div class="home-arrival-card">
                    <!-- Wrapper ảnh có hiệu ứng zoom -->
                    <div class="home-arrival-img-wrapper">
                        <img src="@Url.Content(hinhAnh)" alt="@item.TenSP" class="product-img" />
                    </div>

                    <!-- Phần thông tin (Flexbox để căn chỉnh nút luôn ở đáy) -->
                    <div class="home-arrival-info">
                        <h5 class="product-name" title="@item.TenSP">@item.TenSP</h5>
                        <p class="product-price">@item.GiaHienTai.ToString("N0") ₫</p>

                        <!-- Nút bấm động -->
                        <button class="btn-add-cart"
                                data-id="@item.MaSP"
                                data-name="@item.TenSP"
                                data-price="@item.GiaHienTai"
                                data-bulky="false"
                                data-image="@Url.Content(hinhAnh)"
                                style="...">
                            <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <p>Chưa có sản phẩm nào.</p>
        }
    </div>
</section>

