    .home-arrivals {
        max-width: 1200px;
        margin: 80px auto;
        padding: 0 20px;
        text-align: center;
    }

        .home-arrivals h3.section-title {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 40px;
            color: #2B2623;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .home-arrival-grid {
        display: flex;
        justify-content: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    /* Khung ngoài cùng của Card */
    .home-arrival-card {
        width: 260px; /* Mở rộng thẻ một chút cho thoáng */
        background: #ffffff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.04); /* Đổ bóng cực êm */
        border: 1px solid #f0f0f0;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

        .home-arrival-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

    /* Khu vực chứa ảnh */
    .home-arrival-img-wrapper {
        width: 100%;
        height: 240px;
        overflow: hidden;
        background-color: #f9f9f9;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    /* Hiệu ứng Zoom ảnh khi hover vào thẻ */
    .home-arrival-card:hover .product-img {
        transform: scale(1.08);
    }

    /* Khu vực chứa chữ và nút */
    .home-arrival-info {
        padding: 20px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        text-align: center;
    }

    .product-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #2B2623;
        margin-bottom: 8px;
        line-height: 1.4;
        /* Giới hạn 2 dòng, quá dài hiện dấu ... */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-price {
        font-size: 1.15rem;
        font-weight: 700;
        color: #8b6040; /* Tone màu nâu cũ của bạn */
        margin-bottom: 20px;
    }

    /* Nút bấm Thêm vào giỏ */
    .btn-add-cart {
        background: #2B2623; /* Đen than */
        color: #ffffff;
        padding: 12px 15px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        width: 100%;
        margin-top: auto; /* Đẩy nút xuống dưới cùng, thẳng hàng nhau */
        font-weight: 600;
        font-size: 0.95rem;
        transition: background 0.3s ease, transform 0.2s ease;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
    }

        .btn-add-cart:hover {
            background: #000000;
            transform: scale(1.03); /* Phình to nhẹ khi bấm */
        }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        // Hàm load số lượng giỏ hàng ngay khi mở trang web
        function loadCartCount() {
            $.get('/Cart/GetCartCount', function (res) {
                if (res.count > 0) {
                    $('#cart-badge').text(res.count).fadeIn(); // Hiện bong bóng đỏ
                } else {
                    $('#cart-badge').fadeOut(); // Ẩn nếu giỏ hàng bằng 0
                }
            });
        }

        loadCartCount(); // Chạy ngay lập tức
    });

