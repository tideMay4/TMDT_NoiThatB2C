    $(document).ready(function () {
        $('.btn-add-cart').click(function (e) {
            e.preventDefault();
            let btn = $(this);
            let originalHtml = btn.html(); // Lưu lại HTML cũ (chứa cả icon)

            let productData = {
                productId: btn.data('id'),
                productName: btn.data('name'),
                price: parseFloat(btn.data('price')),
                isBulky: btn.data('bulky'),
                hinhAnh: btn.data('image') // <--- Đọc link ảnh từ nút bấm gửi lên Server
            };

            // Hiệu ứng đang tải
            btn.html('<i class="fa-solid fa-spinner fa-spin"></i> Đang thêm...').prop('disabled', true);

            $.post('/Cart/AddToCart', productData, function (res) {
                if (res.success) {
                    // Cập nhật số lượng trên icon giỏ hàng ở Header
                    $('#cart-badge').text(res.totalItems).fadeIn();

                    // Hiển thị thành công
                    btn.html('<i class="fa-solid fa-check"></i> Đã thêm').css('background', '#8b6040');

                    // Trả lại trạng thái sau 2 giây
                    setTimeout(() => {
                        btn.html(originalHtml).css('background', '#2B2623').prop('disabled', false);
                    }, 2000);
                }
            }).fail(function () {
                alert("Có lỗi xảy ra, không thể thêm vào giỏ hàng.");
                btn.html(originalHtml).prop('disabled', false);
            });
        });
    });
</script>